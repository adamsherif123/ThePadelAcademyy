# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Firebase / FCM service-account key — the real SECRET. Uploaded to EAS credentials,
# NEVER committed. (Multiple spellings: adminsdk downloads, hyphenated, and the
# camelCase name this project's key actually uses.)
*firebase-adminsdk*.json
*service-account*.json
*ServiceAccount*.json
# NOTE: google-services.json is intentionally NOT ignored. It is public client config that
# ships inside the APK, and EAS archives ONLY git-tracked files — ignoring it breaks the
# Android build (google-services.json missing at prebuild). Keep it committed.

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android
