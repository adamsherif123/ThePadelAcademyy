# Copy to .env (gitignored) and fill in from your Supabase project → Settings → API.
#
# EXPO_PUBLIC_* is the only prefix Expo inlines into the client bundle. Both values
# are PUBLIC by design — they ship in the app binary and are protected by Row-Level
# Security, not by secrecy. NEVER put the service_role key here: it is a server
# secret that bypasses RLS and must never reach the client.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Crash reporting (Sentry) — OPTIONAL. Leave empty in dev: reporting is a no-op without
# a DSN and in __DEV__. Paste the DSN from your Sentry project (Settings → Client Keys)
# to activate in production/preview builds. This is a public client ingestion key (not a
# secret). For readable native stacks, also add the plugin + upload source maps — see
# docs/PRODUCTION_CUTOVER.md.
EXPO_PUBLIC_SENTRY_DSN=
