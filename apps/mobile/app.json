{
  "expo": {
    "name": "The Padel Academy",
    "slug": "the-padel-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tpa",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.thepadelacademy.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.thepadelacademy.app",
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#06122f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#06122f",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#06122f"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The Padel Academy uses your photos so you can attach a payment screenshot to a credit request."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "607e2114-b8fd-4b7a-89f5-d9f6f1584824"
      },
      "router": {}
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "adamsherif123"
  }
}
