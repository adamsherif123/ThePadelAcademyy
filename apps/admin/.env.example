# Copy to .env (gitignored) and fill in from your Supabase project → Settings → API.
#
# VITE_* is the only prefix Vite exposes to the client bundle. Both values are PUBLIC
# by design — they ship in the JS bundle and are protected by Row-Level Security, not
# by secrecy. NEVER put the service_role key here: it bypasses RLS and must never
# reach the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
