# Copy to .env (gitignored) and fill in from your Supabase project → Settings → API.
#
# VITE_* is the only prefix Vite exposes to the client bundle. Both values are PUBLIC
# by design — they ship in the JS bundle and are protected by Row-Level Security, not
# by secrecy. NEVER put the service_role key here: it bypasses RLS and must never
# reach the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Crash reporting (Sentry) — OPTIONAL. Leave empty in dev: reporting is a no-op without
# a DSN and in dev. Paste the DSN from your Sentry project (Settings → Client Keys) to
# activate in production builds. Public client ingestion key (not a secret). Source-map
# upload at build time is a cutover step — see docs/PRODUCTION_CUTOVER.md.
VITE_SENTRY_DSN=
