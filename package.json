{
  "name": "the-padel-academy",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "mobile": "pnpm --filter mobile start",
    "admin": "pnpm --filter admin dev",
    "typecheck": "pnpm -r --no-bail typecheck",
    "lint": "pnpm -r --no-bail lint",
    "test": "vitest run",
    "test:db": "bash supabase/tests/pgtap.sh",
    "test:concurrency": "bash supabase/tests/concurrency.sh",
    "test:auth": "bash supabase/tests/auth_session.sh",
    "config:check": "node scripts/check-config.mjs",
    "config:push": "node scripts/check-config.mjs --prod && supabase config push",
    "verify": "node scripts/check-config.mjs && pnpm typecheck && pnpm lint && pnpm test && pnpm test:db && pnpm test:concurrency && pnpm test:auth"
  },
  "devDependencies": {
    "tsx": "^4.23.1",
    "vitest": "4.1.10"
  }
}
